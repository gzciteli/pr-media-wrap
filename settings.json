  "defaultTemplate": [
    {
      "type": "header",
      "title": "MEDIA COVERAGE WRAP: [CAMPAIGN TITLE]",
      "importKey": "doc_title"
    },
    {
      "type": "html-block",
      "html": "<p><a href=\"#\" style=\"color:var(--accent,#2178a0);text-decoration:none\">[Press release title]</a> issued by [Organization] on [topic].</p>",
      "importKey": "intro_text"
    },
    {
      "type": "stats",
      "items": [
        {
          "value": "0",
          "label": "Total Potential Reach"
        },
        {
          "value": "0",
          "label": "Unique Stories"
        },
        {
          "value": "0",
          "label": "Total Placements"
        }
      ],
      "importKey": "summary_stats"
    },
    {
      "type": "section-heading",
      "text": "Top-Tier Domestic Coverage"
    },
    {
      "type": "major-grid",
      "importKey": "featured"
    },
    {
      "type": "section-heading",
      "text": "Additional Domestic Coverage"
    },
    {
      "type": "minor-table",
      "importKey": "domestic"
    },
    {
      "type": "section-heading",
      "text": "International Coverage"
    },
    {
      "type": "minor-table",
      "importKey": "international"
    },
    {
      "type": "html-block",
      "html": "<p style=\"font-size:12px;color:#777\">Includes all mentions [start date] through [end date] EOD.</p>",
      "importKey": "footer_text"
    }
  ]
}
